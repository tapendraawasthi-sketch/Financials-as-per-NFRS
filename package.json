{
  "name": "nfrs-financials",
  "version": "1.0.0",
  "description": "Nepal NFRS/NAS financial reporting automation web application",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/server.ts\"",
    "build": "vite build && esbuild server/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:exceljs --external:@anthropic-ai/sdk --external:multer --external:express --sourcemap",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "npx tsc --noEmit",
    "test": "tsx scripts/test-full-flow.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
