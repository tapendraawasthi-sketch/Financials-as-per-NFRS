{
  "name": "nfrs-financials",
  "version": "1.0.0",
  "description": "Nepal NFRS/NAS financial reporting automation web application",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^6.2.3",
    "@tailwindcss/vite": "^4.1.14",
    "tailwindcss": "^4.1.14",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "exceljs": "^4.4.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "typescript": "~5.8.2",
    "tsx": "^4.21.0",
    "esbuild": "^0.25.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21"
  }
}
