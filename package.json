{
  "name": "nfrs-financials",
  "version": "2.0.0",
  "description": "Nepal NAS for MEs / NFRS financial reporting automation",
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/server.ts\"",
    "build": "vite build && esbuild server/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/integration/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^10.0.3",
    "dotenv": "^17.0.0",
    "esbuild": "^0.25.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.0.0",
    "multer": "^2.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
